{
    "version": 2,
    "builds": [
        {
            "src": "static/**/*",
            "use": "@vercel/static"
        },
        {
            "src": "crm.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/static/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/crm.py"
        }
    ]
}
